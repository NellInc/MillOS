{
  "name": "grain-mill-simulator",
  "private": true,
  "version": "0.30.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port 3000",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "bench": "vitest bench",
    "typecheck": "tsc --noEmit -p tsconfig.typecheck.json",
    "lint": "eslint src",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,css}\"",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "setup:basis": "./scripts/setup-basis-transcoder.sh",
    "convert-textures": "node scripts/convert-textures.mjs",
    "convert-textures:dry": "node scripts/convert-textures.mjs --dry-run",
    "optimize-assets": "node scripts/optimize-assets.mjs",
    "optimize-assets:dry": "node scripts/optimize-assets.mjs --dry-run"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@mlc-ai/web-llm": "^0.2.84",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.4.2",
    "@react-three/postprocessing": "^3.0.4",
    "@react-three/rapier": "^2.2.0",
    "@rollup/rollup-darwin-arm64": "^4.54.0",
    "@tailwindcss/postcss": "^4.1.18",
    "framer-motion": "^12.23.26",
    "lucide-react": "^0.562.0",
    "maath": "^0.10.8",
    "peerjs": "^1.5.5",
    "postprocessing": "^6.38.2",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "recharts": "^3.6.0",
    "three": "^0.182.0",
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@gltf-transform/cli": "^4.2.1",
    "@playwright/test": "^1.57.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.0.3",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.182.0",
    "@typescript-eslint/parser": "^8.50.1",
    "@vitejs/plugin-react-swc": "^4.2.2",
    "@vitest/coverage-v8": "^4.0.16",
    "autoprefixer": "^10.4.23",
    "eslint": "^9.39.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^16.5.0",
    "jsdom": "^27.4.0",
    "postcss": "^8.5.6",
    "prettier": "^3.7.4",
    "puppeteer": "^24.34.0",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.50.1",
    "vite": "^7.3.0",
    "vitest": "^4.0.16"
  },
  "overrides": {
    "stats-gl": {
      "three": "^0.182.0"
    },
    "tunnel-rat": {
      "zustand": "^5.0.0"
    }
  }
}
